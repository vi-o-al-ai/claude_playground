{
  "name": "ai-games-arcade",
  "version": "1.0.0",
  "private": true,
  "description": "A browser-based collection of interactive games built with diverse tech stacks",
  "type": "module",
  "workspaces": [
    "games/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspace",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run lint && npm run format:check && npm run test",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vi-o-al-ai/claude_playground"
  },
  "keywords": [
    "games",
    "arcade",
    "html5",
    "canvas",
    "browser-games"
  ],
  "author": "vi-o-al-ai",
  "license": "MIT",
  "lint-staged": {
    "*.js": "eslint",
    "*.html": "eslint"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-html": "^8.1.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
